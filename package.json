{
  "name": "@brutalsystems/forge",
  "version": "0.3.0",
  "description": "Local dev process orchestration daemon with web dashboard",
  "main": "src/daemon/server.js",
  "bin": {
    "forge": "./bin/forge.js"
  },
  "files": [
    "bin/",
    "src/",
    "web/dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/daemon/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:web": "vite build --config web/vite.config.js",
    "dev:web": "vite --config web/vite.config.js"
  },
  "jest": {
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dockerode": "^5.0.0",
    "express": "^4.18.0",
    "node-pty": "^1.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "jest": "^29.0.0",
    "supertest": "^7.0.0",
    "vite": "^8.0.14"
  }
}
